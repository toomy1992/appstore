{
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json",
  "schemaVersion": 2,
  "services": [
    {
      "name": "maigret",
      "image": "soxoj/maigret:web",
      "isMain": true,
      "internalPort": 5000,
      "restart": "unless-stopped",
      "entrypoint": ["sh", "-c", "pip install --quiet 'maigret[pdf]' 2>/dev/null; exec maigret --web \"$PORT\""],
      "environment": [
        {
          "key": "PORT",
          "value": "${MAIGRET_PORT:-5000}"
        },
        {
          "key": "OPENAI_API_KEY",
          "value": "${MAIGRET_OPENAI_API_KEY:-}"
        },
        {
          "key": "FLARESOLVERR_URL",
          "value": "${MAIGRET_FLARESOLVERR_URL:-}"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/reports",
          "containerPath": "/app/reports"
        }
      ]
    }
  ]
}
